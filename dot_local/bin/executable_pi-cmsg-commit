#!/usr/bin/env bash

set -Eeuo pipefail

allowed_types='fix|feat|build|chore|ci|docs|style|refactor|perf|test'
model='google/gemini-2.5-flash-lite'

fail() {
  printf 'pi-cmsg-commit: %s\n' "$*" >&2
  exit 1
}

command -v git >/dev/null 2>&1 || fail "git is not installed"
command -v pi >/dev/null 2>&1 || fail "pi is not installed"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "not inside a git repository"

if git diff --cached --quiet --exit-code; then
  fail "no staged changes"
fi

if [[ -z "${PI_CODING_AGENT_DIR:-}" ]]; then
  xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  export PI_CODING_AGENT_DIR="$xdg_config_home/pi"
fi

diff_output="$(git diff --cached --no-ext-diff --unified=3 -- .)"
[[ -n "$diff_output" ]] || fail "staged diff is empty"

prompt_file="$(mktemp)"
trap 'rm -f "$prompt_file"' EXIT

cat >"$prompt_file" <<EOF
Write exactly one conventional commit message for the staged git diff below.

Rules:
- Output the commit message only.
- Use exactly one type: fix, feat, build, chore, ci, docs, style, refactor, perf, or test.
- Use format: type: subject or type(scope): subject.
- Include a scope only when it is obvious from the diff.
- Keep the whole line under 72 characters.
- Use imperative mood.
- Start the subject with a lowercase letter or number.
- Do not end with a period.
- Do not use markdown, quotes, backticks, commentary, or multiple lines.
- Base the message only on this staged diff.

Staged diff:
$diff_output
EOF

if ! raw_output="$(
  pi \
    --print \
    --no-session \
    --no-tools \
    --no-context-files \
    --no-skills \
    --no-prompt-templates \
    --model "$model" \
    --thinking off \
    @"$prompt_file" |
    sed -e 's/\x1b\[[0-9;]*m//g'
)"; then
  fail "pi failed to generate a commit message"
fi

message="$(printf '%s\n' "$raw_output" | sed -e '/^[[:space:]]*$/d')"
message="${message//$'\r'/}"

if [[ -z "$message" ]]; then
  fail "pi returned an empty commit message"
fi

line_count="$(printf '%s\n' "$message" | awk 'END { print NR }')"
if [[ "$line_count" != "1" ]]; then
  printf '%s\n' "$message" >&2
  fail "pi returned multiple lines"
fi

if [[ "$message" == '```'* || "$message" == *'```'* ]]; then
  printf '%s\n' "$message" >&2
  fail "pi returned markdown formatting"
fi

if ! [[ "$message" =~ ^($allowed_types)(\([A-Za-z0-9._/-]+\))?:\ .+ ]]; then
  printf '%s\n' "$message" >&2
  fail "message must match conventional commit format"
fi

subject="${message#*: }"

if [[ ${#message} -gt 72 ]]; then
  printf '%s\n' "$message" >&2
  fail "message is longer than 72 characters"
fi

first_char="${subject:0:1}"
if [[ "$first_char" =~ [A-Z] ]]; then
  printf '%s\n' "$message" >&2
  fail "subject must start with lowercase text"
fi

if [[ "$subject" == *. ]]; then
  printf '%s\n' "$message" >&2
  fail "subject must not end with a period"
fi

printf 'Generated commit message:\n%s\n' "$message"
git commit -m "$message"
