#!/usr/bin/env bash

set -Eeuo pipefail

allowed_types='fix|feat|build|chore|ci|docs|style|refactor|perf|test|revert'
model='google/gemini-2.5-flash-lite'
max_attempts=3
script_name='pi-cmsg-commit'
tmpdir=''
prompt_file=''
commit_msg_file=''

fail() {
  printf '%s: %s\n' "$script_name" "$*" >&2
  exit 1
}

log_error() {
  printf '%s: %s\n' "$script_name" "$*" >&2
}

cleanup() {
  if [[ -n "$tmpdir" && -d "$tmpdir" ]]; then
    rm -rf -- "$tmpdir"
  fi
}

on_err() {
  local exit_code="$1"
  local line_no="$2"
  log_error "unexpected error on line $line_no (exit $exit_code)"
  exit "$exit_code"
}

check_dependencies() {
  local -a missing=()
  local cmd=''

  for cmd in git pi; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done

  if ((${#missing[@]} > 0)); then
    fail "missing required commands: ${missing[*]}"
  fi
}

trap 'cleanup' EXIT
trap 'on_err $? $LINENO' ERR

check_dependencies

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "not inside a git repository"

if git diff --cached --quiet --exit-code; then
  fail "no staged changes"
fi

if [[ -z "${PI_CODING_AGENT_DIR:-}" ]]; then
  xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  export PI_CODING_AGENT_DIR="$xdg_config_home/pi"
fi

diff_output="$(git diff --cached --no-ext-diff --unified=3 -- .)"
[[ -n "$diff_output" ]] || fail "staged diff is empty"

tmpdir="$(mktemp -d)"
prompt_file="$tmpdir/prompt.txt"
commit_msg_file="$tmpdir/commit-message.txt"

build_prompt() {
  local attempt="$1"
  local feedback="${2:-}"
  local previous_output="${3:-}"

  cat >"$prompt_file" <<EOF
Write a Conventional Commit message for the staged git diff below.

Requirements:
- Output only the commit message
- Use one of these types: fix, feat, build, chore, ci, docs, style, refactor, perf, test, revert
- Use header format: type: subject or type(scope): subject
- You may use ! for a breaking change
- Keep the header at or under 72 characters
- Start the subject with a lowercase letter or number
- Do not end the subject with a period
- Omit scope unless it clearly helps disambiguate the change
- Choose the type by audience impact first: feat for user-visible capability, fix for corrected behavior, build for packaging/build/release/versioning, ci for automation, chore for internal maintenance
- For broad changes, prefer the user-facing outcome or repo-level intent over low-level mechanisms
- Write a specific, concrete subject with a strong verb and plain nouns
- Prefer slightly intent-bearing subjects like "adopt changesets for release management" over flat diff narration like "add changesets"
- Avoid vague or generic subjects like: update, improve, enhance, optimize, streamline, clean up, misc fixes, refactor code
- Avoid weak nouns like: functionality, capabilities, improvements, enhancements, optimization
- Prefer a header-only commit message unless the diff needs non-obvious rationale
- Add a body only when it explains why, impact, or a constraint that is not obvious from the diff
- If you add a body, keep it to one short paragraph, max 4 wrapped lines
- Do not narrate the diff, list files, list dependencies, or summarize changes file-by-file
- Do not start the body with "This commit"
- Base the message only on this staged diff
- Do not use markdown fences, quotes, or commentary
EOF

  if [[ "$attempt" -gt 1 ]]; then
    cat >>"$prompt_file" <<EOF

Previous output was invalid.
Validation failure: $feedback
Previous output:
$previous_output
EOF
  fi

  cat >>"$prompt_file" <<EOF

Staged diff:
$diff_output
EOF
}

generate_message() {
  if ! raw_output="$({
    pi \
      --print \
      --no-session \
      --no-tools \
      --no-context-files \
      --no-skills \
      --no-prompt-templates \
      --model "$model" \
      --thinking off \
      @"$prompt_file"
  } | sed -e 's/\x1b\[[0-9;]*m//g')"; then
    fail "pi failed to generate a commit message"
  fi
}

normalize_and_validate() {
  local input="$1"
  local -a lines=()
  local line=''
  local header=''
  local body_line_count=0
  local idx=0

  input="${input//$'\r'/}"

  while IFS= read -r line; do
    lines+=("$line")
  done <<<"$input"

  while ((${#lines[@]} > 0)) && [[ -z "${lines[0]//[[:space:]]/}" ]]; do
    lines=("${lines[@]:1}")
  done

  while ((${#lines[@]} > 0)) && [[ -z "${lines[${#lines[@]} - 1]//[[:space:]]/}" ]]; do
    unset 'lines[${#lines[@]}-1]'
  done

  if ((${#lines[@]} == 0)); then
    printf 'ERROR: pi returned an empty commit message\n'
    return 1
  fi

  header="${lines[0]}"

  if [[ "$header" == *'```'* || "$header" == '"'* || "$header" == *'"' || "$header" == "'"* || "$header" == *"'" ]]; then
    printf 'ERROR: header must not use markdown fences or quotes\n'
    return 1
  fi

  if [[ ! "$header" =~ ^(${allowed_types})(\([A-Za-z0-9._/-]+\))?(!)?:\ .+ ]]; then
    printf 'ERROR: header must match conventional commit format\n'
    return 1
  fi

  if ((${#header} > 72)); then
    printf 'ERROR: header is longer than 72 characters\n'
    return 1
  fi

  for ((idx = 1; idx < ${#lines[@]}; idx++)); do
    if [[ -n "${lines[idx]//[[:space:]]/}" ]]; then
      body_line_count=$((body_line_count + 1))
    fi
  done

  if ((body_line_count > 4)); then
    printf 'ERROR: body must be 4 lines or fewer\n'
    return 1
  fi

  printf '%s\n' "$input"
}

attempt=1
feedback=''
previous_output=''
message=''
validation_output=''

while ((attempt <= max_attempts)); do
  build_prompt "$attempt" "$feedback" "$previous_output"
  generate_message

  trap - ERR
  set +e
  validation_output="$(normalize_and_validate "$raw_output")"
  validation_status=$?
  set -e
  trap 'on_err $? $LINENO' ERR

  if ((validation_status == 0)); then
    message="$validation_output"
    break
  fi

  feedback="$(printf '%s\n' "$validation_output" | sed 's/^ERROR: //')"
  previous_output="$raw_output"

  if ((attempt < max_attempts)); then
    printf '%s: retrying after validation failure: %s\n' "$script_name" "$feedback" >&2
  fi

  if ((attempt == max_attempts)); then
    printf 'Model: %s\n' "$model" >&2
    printf 'Last output:\n%s\n' "$raw_output" >&2
    fail "$feedback"
  fi

  attempt=$((attempt + 1))
done

printf '%s\n' "$message" >"$commit_msg_file"
printf 'Model: %s\n' "$model"
printf 'Generated commit message:\n%s\n' "$message"
git commit -F "$commit_msg_file"
