[Unit]
Description=nullclaw gateway runtime
After=network.target

[Service]
Type=simple
# ~/.secrets is bash (export KEY=...); systemd EnvironmentFile cannot parse that.
ExecStart=/bin/bash -c 'set -a; source /home/eddies/.secrets; set +a; exec /home/linuxbrew/.linuxbrew/bin/nullclaw gateway'
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
