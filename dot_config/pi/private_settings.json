{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "lastChangelogVersion": "0.78.1",
  "quietStartup": false,
  "enableInstallTelemetry": false,
  "npmCommand": [
    "bun"
  ],
  "theme": "dark",
  "treeFilterMode": "user-only",
  "packages": [
    "../../personal/pi-extensions/packages/pi-copy-response",
    "../../personal/pi-extensions/packages/pi-handoff",
    "../../personal/pi-extensions/packages/pi-inline-skills",
    "../../personal/pi-extensions/packages/pi-mermaid-open",
    "../../personal/pi-extensions/packages/pi-preferred-thinking",
    "../../personal/pi-extensions/packages/pi-recap",
    "../../personal/pi-extensions/packages/pi-fixed-editor",
    "../../personal/pi-extensions/packages/pi-rename",
    "npm:pi-fff",
    "npm:pi-code-previews",
    "npm:pi-add-dir",
    "npm:@fitchmultz/pi-stash",
    "npm:pi-codex-goal",
    "npm:pi-rtk-optimizer",
    "npm:pi-mcp-adapter",
    "npm:pi-subdir-context",
    "npm:@ogulcancelik/pi-herdr",
    "npm:@gotgenes/pi-subagents",
    "npm:@juicesharp/rpiv-ask-user-question"
  ],
  "enableSkillCommands": false,
  "terminal": {
    "showTerminalProgress": false,
    "clearOnShrink": false
  },
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4-mini"
  ],
  "transport": "websocket-cached",
  "compaction": {
    "enabled": false
  },
  "collapseChangelog": true,
  "showHardwareCursor": false,
  "retry": {
    "enabled": true
  }
}