# ------------------------------ GENERAL ---------------------------------------

macos-titlebar-style = hidden

confirm-close-surface = false
copy-on-select = true

macos-option-as-alt = true

theme = light:Gruvbox Light Hard,dark:IR Black

custom-shader = shaders/cursors/cursor_warp.glsl
custom-shader-animation = always

maximize = true

# default mac behaviour is false, linux is true
# if false, `zka` won't quit ghostty
quit-after-last-window-closed = true

font-family = "CommitMono Nerd Font"
font-size = 14
font-thicken = true

window-save-state = never

# window-padding-balance = true

background-opacity = 1.0
background-blur = true

# Opacity for unfocused splits (0.0 to 1.0)
unfocused-split-opacity = 0.7
unfocused-split-fill = #000000
split-divider-color = #000000

# ------------------------------ KEYBINDS --------------------------------------
# Defaults: ghostty +list-keybinds --default
# Current: ghostty +list-keybinds

# -------------- MODIFIED
# keybind = super+r=reload_config

# Herdr owns tabs/splits/panes. Disable Ghostty's native layout shortcuts so
# accidental Command-W/D doesn't close or split the underlying terminal surface.
keybind = super+w=unbind
keybind = super+alt+w=unbind
keybind = super+shift+w=unbind
keybind = super+alt+shift+w=unbind
keybind = super+d=unbind
keybind = super+shift+d=unbind
keybind = super+n=unbind
keybind = super+x=unbind

# Herdr owns tabs.
keybind = super+t=unbind
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind
keybind = super+9=unbind

# Herdr owns panes/splits.
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+alt+arrow_up=unbind
keybind = super+alt+arrow_down=unbind
keybind = super+alt+arrow_left=unbind
keybind = super+alt+arrow_right=unbind
keybind = super+ctrl+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+ctrl+==unbind
keybind = super+enter=unbind
keybind = super+shift+enter=unbind

keybind = super+s=write_scrollback_file:open
