{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/.config/codex/herdr-agent-state.sh\" working'",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/.config/codex/herdr-agent-state.sh\" idle'",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/tifan/.config/codex/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/.config/codex/herdr-agent-state.sh\" idle'",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/.config/codex/herdr-agent-state.sh\" working'",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}