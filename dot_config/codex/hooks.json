{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/herdr-agent-state.sh\" idle'",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/herdr-agent-state.sh\" working'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/herdr-agent-state.sh\" working'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/herdr-agent-state.sh\" idle'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
