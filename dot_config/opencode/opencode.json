{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "disabled_providers": ["openrouter"],
  "model": "opencode/kimi-k2.5-free",
  "small_model": "google/gemini-2.5-flash-lite",

  "permission": {
    "bash": {
      "git push *": "ask",
      "git commit *": "ask",
      "git add *": "ask"
    },
    "external_directory": {
      "~/personal/**": "allow",
      "~/work/**": "allow",
      "~/.config/**": "allow"
    }
  },

