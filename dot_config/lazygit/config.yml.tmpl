# chezmoi:template:left-delimiter="# {{" right-delimiter=}}
# yaml-language-server: $schema=https://raw.githubusercontent.com/jesseduffield/lazygit/master/schema/config.json
os:
  # {{ if eq .chezmoi.os "darwin" }}
  open: "bash -c 'open {{filename}}'"
  # {{ else }}
  open: "bash -c 'xdg-open {{filename}}'"
  # {{ end }}
git:
  overrideGpg: true
  # {{ if eq .chezmoi.os "darwin" }}
  pagers:
    - pager: delta --paging=never --line-numbers --hyperlinks --hyperlinks-file-link-format="lazygit-edit://{path}:{line}"
      colorArg: always
# {{ end }}

gui:
  expandFocusedSidePanel: true
  expandedSidePanelWeight: 99
  border: "single"
  showPanelJumps: true
  showFileTree: true
  sidePanelWidth: 0.22
  showBottomLine: false
  theme:
    selectedLineBgColor:
      - reverse
notARepository: "quit"
promptToReturnFromSubprocess: false
keybinding:
  files:
    commitChangesWithEditor: <disabled>
# {{ if eq .chezmoi.os "darwin" -}}
customCommands:
  - key: "C"
    context: "files"
    description: "Generate commit message"
    command: "{{ .Form.generator }}"
    prompts:
      - type: "menu"
        title: "Generate with"
        key: "generator"
        options:
          - name: "Claude"
            value: "claude-cmsg-commit"
          - name: "Pi"
            value: "pi-cmsg-commit"
    output: "log"
    loadingText: "Generating commit message..."
  - key: "G"
    context: "localBranches,commits"
    description: "Create PR with Pi"
    command: "pi-pr-create"
    output: "log"
    loadingText: "Creating PR..."
  - key: "Y"
    context: global
    description: "Open repository in browser"
    command: "gh repo view --web"
  - key: "U"
    context: "localBranches,commits"
    description: "Rebase onto upstream"
    command: 'bash -c ''git remote get-url upstream > /dev/null 2>&1 || { echo "Error: upstream remote not found"; exit 1; } && git fetch upstream --tags && git rebase $(git describe --tags --abbrev=0 upstream/HEAD)'''
    output: "log"
# {{ end -}}
