#!/usr/bin/env bash

# chezmoi:template:left-delimiter="# {{" right-delimiter=}}
# Brewfile hash: # {{ include "dot_Brewfile.tmpl" | sha256sum }}

if command -v brew &>/dev/null; then
  # Rendered Brewfile (hostname/OS conditionals); not the raw .tmpl in source.
  brew bundle --cleanup --file="# {{ printf "%s/.Brewfile" .chezmoi.destDir }}"
fi
